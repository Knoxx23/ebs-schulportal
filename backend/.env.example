NODE_ENV=production
PORT=3001

# WICHTIG: Beide Secrets in Produktion ändern! Zufällige lange Zeichenkette verwenden.
JWT_SECRET=HIER-EIGENEN-GEHEIMEN-SCHLUESSEL-EINSETZEN
COOKIE_SECRET=HIER-EIGENEN-COOKIE-SCHLUESSEL-EINSETZEN

DB_PATH=./data/ebs.db
DOCUMENTS_PATH=./data/documents
TEMPLATE_PATH=./EBS_blanko.doc

# Die öffentliche URL der App (für E-Mail-Links)
APP_URL=https://ebs.deine-domain.de

# SMTP E-Mail Konfiguration (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM=noreply@schule.de
